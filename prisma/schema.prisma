generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(cuid())
  name      String
  /// HWPX binary stored as base64-encoded blob
  hwpxBlob  Bytes
  /// ProseMirror JSON doc snapshot
  docJson   String
  /// Segments JSON
  segments  String
  /// Extra segments map JSON
  extraSegmentsMap String @default("{}")
  /// Size in bytes of the original HWPX file
  sizeBytes Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions  DocumentVersion[]

  @@index([updatedAt])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  /// ProseMirror JSON doc snapshot at this version
  docJson    String
  /// Human label: "auto-save", "manual-save", "ai-edit", etc.
  label      String   @default("save")
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model ApiKeyConfig {
  id        String   @id @default(cuid())
  /// User email (unique per provider)
  userEmail String
  /// "anthropic" | "openai"
  provider  String
  /// AES-256-GCM encrypted key (base64)
  encryptedKey String
  /// AES IV (base64)
  iv        String
  /// AES auth tag (base64)
  authTag   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userEmail, provider])
}

model AuditLog {
  id        String   @id @default(cuid())
  /// User email or "system"
  userEmail String
  /// "ai-suggest" | "ai-batch" | "ai-chat" | "ai-verify" | "document-save" | ...
  action    String
  /// Endpoint path
  endpoint  String
  /// Optional details JSON
  details   String   @default("{}")
  createdAt DateTime @default(now())

  @@index([userEmail, createdAt])
  @@index([action, createdAt])
}

// ─── RLHF Training Infrastructure ──────────────────────────────────────────

/// A named family of reports sharing the same PPTX→Report transformation pattern.
/// e.g. "accelerator-final-report", "impact-investment-review"
model ReportFamily {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packets        TrainingPacket[]
  schemas        FamilySchemaVersion[]
  generationRuns GenerationRun[]

  @@index([name])
}

/// Versioned schema capturing the abstract TOC + transformation rules for a family.
/// Allows evolution without losing history.
model FamilySchemaVersion {
  id       String @id @default(cuid())
  familyId String
  version  Int    @default(1)

  /// Normalized TOC structure JSON (array of {id, title, sectionType})
  tocSchemaJson String
  /// JSON: SlideTypePattern[] — abstract slide type definitions for this family
  slideTypePatternsJson String @default("[]")
  /// JSON: TransformationRule[] — slide_type → report_section mappings
  transformationRulesJson String @default("[]")

  /// "draft" | "active" | "deprecated"
  status    String   @default("draft")
  createdAt DateTime @default(now())

  family ReportFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, version])
  @@index([familyId, status])
}

/// A single PPTX+Report pair used as a training/benchmark example.
/// Contains extracted slide classifications and transformation pairs.
model TrainingPacket {
  id       String @id @default(cuid())
  familyId String

  /// JSON: {slideDeckFile: string, reportFile: string, uploadedAt: string}
  sourceArtifactsJson String

  /// JSON: SlideClassification[] — per-slide abstract type classifications
  slideClassificationsJson String @default("[]")
  /// JSON: ReportSectionClassification[] — per-section abstract type classifications
  reportSectionClassificationsJson String @default("[]")
  /// JSON: TransformationPair[] — aligned (slideType → sectionType) pairs with metadata
  transformationPairsJson String @default("[]")

  /// "pending" | "reviewed" | "gold"
  /// gold = human-verified, used as ground truth for evaluation
  status        String    @default("pending")
  reviewerEmail String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())

  family ReportFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, status])
  @@index([createdAt])
}

// ─── RLHF Human Feedback Infrastructure ─────────────────────────────────────

/// Records a single AI draft generation attempt.
/// Linked to HumanFeedback entries when the user edits the output.
model GenerationRun {
  id       String @id @default(cuid())
  familyId String

  /// JSON: ReportFamilyPlan used for generation
  planJson       String
  /// JSON: ReportFamilyDraft produced
  draftJson      String
  /// JSON: ReportFamilyDraftEvaluation (automatic quality metrics)
  evaluationJson String @default("{}")
  /// Model used (e.g. "gpt-4.1-mini")
  model          String @default("")

  inputTokens  Int @default(0)
  outputTokens Int @default(0)

  /// "pending_review" | "accepted" | "rejected" | "superseded"
  status    String   @default("pending_review")
  createdAt DateTime @default(now())

  family    ReportFamily  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  feedbacks HumanFeedback[]

  @@index([familyId, status])
  @@index([createdAt])
}

/// Captures a single human correction to an AI-generated section.
/// The diff between aiContentJson and humanContentJson is the learning signal.
model HumanFeedback {
  id              String  @id @default(cuid())
  generationRunId String?

  /// "section_edit" | "section_accept" | "section_reject" | "global_note"
  feedbackType String
  /// tocEntryId of the section this feedback applies to
  sectionId    String?

  /// JSON: the AI-generated section content (before edit)
  aiContentJson    String?
  /// JSON: the human-edited section content (after edit)
  humanContentJson String?
  /// JSON: structured diff (added/removed paragraphs, table changes)
  diffJson         String?
  /// JSON: abstract correction pattern (e.g. "removed_hallucination", "added_context_paragraph")
  correctionPatternJson String?

  /// 1-5 quality rating for the AI output (1=very bad, 5=perfect)
  qualityScore  Int?
  reviewerEmail String
  notes         String @default("")

  createdAt DateTime @default(now())

  generationRun GenerationRun? @relation(fields: [generationRunId], references: [id], onDelete: SetNull)

  @@index([generationRunId, createdAt])
  @@index([sectionId, feedbackType])
  @@index([createdAt])
}

/// Stores a (chosen, rejected) preference pair derived from human feedback.
/// "chosen" = human-edited version, "rejected" = original AI output.
/// Used in Phase 3 for prompt memory building.
model PreferenceData {
  id          String @id @default(cuid())
  familyId    String
  sectionType String

  /// JSON: the preferred (human-edited) section content
  chosenJson  String
  /// JSON: the rejected (AI-generated) section content
  rejectedJson String
  /// JSON: abstract correction pattern(s) describing the difference
  correctionPatternJson String

  sourceFeedbackId String?
  createdAt        DateTime @default(now())

  @@index([familyId, sectionType])
  @@index([createdAt])
}

// ─── RLHF Prompt Optimization Infrastructure ─────────────────────────────────

/// A distilled memory entry injected into generation prompts to guide AI output.
/// Built from accumulated human feedback: few-shot examples, negative examples,
/// and instruction rules derived from recurring correction patterns.
model PromptMemory {
  id          String  @id @default(cuid())
  /// null = cross-family (applies to all families)
  familyId    String?
  sectionType String

  /// "few_shot_example" | "negative_example" | "instruction_rule"
  memoryType String

  /// JSON: memory content (varies by type)
  /// few_shot_example: {input: SectionPromptPlan, output: ReportFamilyDraftSection}
  /// negative_example: {badExample: ReportFamilyDraftSection, reason: string}
  /// instruction_rule: {rule: string, rationale: string}
  contentJson String

  /// JSON: source HumanFeedback/PreferenceData IDs this was derived from
  sourceFeedbackIds String @default("[]")

  /// Higher = inject first (more important)
  priority Int @default(0)

  /// "active" | "deprecated"
  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId, sectionType, status])
  @@index([memoryType, status])
}
